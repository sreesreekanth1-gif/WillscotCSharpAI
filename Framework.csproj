<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Playwright" Version="1.51.0" />
    <None Update="Configuration\appsettings.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Update="allureConfig.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <PackageReference Include="NUnit" Version="4.5.1" />
    <PackageReference Include="NUnit3TestAdapter" Version="6.2.0" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="18.3.0" />
    <PackageReference Include="Allure.Commons" Version="3.5.0.73" />
    <PackageReference Include="Allure.NUnit" Version="2.14.1" />
    <PackageReference Include="Allure.Net.Commons" Version="2.14.1" />
    <PackageReference Include="Microsoft.Extensions.Configuration" Version="8.0.0" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Json" Version="8.0.1" />
    <PackageReference Include="Microsoft.Extensions.Configuration.EnvironmentVariables" Version="8.0.0" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Binder" Version="8.0.2" />
    <PackageReference Include="ClosedXML" Version="0.105.0" />
    <PackageReference Include="Serilog" Version="4.3.1" />
    <PackageReference Include="Serilog.Sinks.Console" Version="6.1.1" />
  </ItemGroup>

  <Target Name="CleanAllureResults" BeforeTargets="VSTest">
    <PropertyGroup>
      <AllureResultsDir>$(OutputPath)allure-results</AllureResultsDir>
    </PropertyGroup>
    <Message Text="Cleaning allure-results from previous runs..." Importance="high" />
    <Exec Command="powershell.exe -NoProfile -Command &quot;if (Test-Path '$(AllureResultsDir)') { Remove-Item '$(AllureResultsDir)\*' -Recurse -Force -ErrorAction SilentlyContinue }&quot;"
          IgnoreExitCode="true" />
  </Target>

  <Target Name="GenerateAllureReport" AfterTargets="VSTest">
    <PropertyGroup>
      <AllureResultsDir>$(OutputPath)allure-results</AllureResultsDir>
      <AllureReportDir>$(MSBuildProjectDirectory)\Reports</AllureReportDir>
      <AppSettingsFile>$(MSBuildProjectDirectory)\Configuration\appsettings.json</AppSettingsFile>
      <AllureConfigRoot>$(MSBuildProjectDirectory)\allureConfig.json</AllureConfigRoot>
      <AllureConfigOut>$(OutputPath)allureConfig.json</AllureConfigOut>
      <SetTitleScript>$(MSBuildProjectDirectory)\set-report-title.ps1</SetTitleScript>
    </PropertyGroup>
    <!-- Step 1: inject ReportTitle into all allureConfig.json copies so allure generate picks it up -->
    <Exec Command="powershell.exe -NoProfile -File &quot;$(SetTitleScript)&quot; -AppSettingsFile &quot;$(AppSettingsFile)&quot; -AllureConfigRoot &quot;$(AllureConfigRoot)&quot; -AllureConfigOut &quot;$(AllureConfigOut)&quot; -AllureResultsDir &quot;$(AllureResultsDir)&quot; -ReportHtml &quot;$(AllureReportDir)\index.html&quot;"
          IgnoreExitCode="true" />
    <!-- Step 2: generate the report -->
    <Message Text="Generating Allure report from $(AllureResultsDir)..." Importance="high" />
    <Exec Command="allure generate &quot;$(AllureResultsDir)&quot; --clean --single-file -o &quot;$(AllureReportDir)&quot;"
          IgnoreExitCode="true" />
    <!-- Step 3: patch the browser tab title in the generated HTML -->
    <Exec Command="powershell.exe -NoProfile -File &quot;$(SetTitleScript)&quot; -AppSettingsFile &quot;$(AppSettingsFile)&quot; -AllureConfigRoot &quot;$(AllureConfigRoot)&quot; -AllureConfigOut &quot;$(AllureConfigOut)&quot; -AllureResultsDir &quot;$(AllureResultsDir)&quot; -ReportHtml &quot;$(AllureReportDir)\index.html&quot;"
          IgnoreExitCode="true" />
    <Message Text="Allure report generated at $(AllureReportDir)\index.html" Importance="high" />
  </Target>
</Project>